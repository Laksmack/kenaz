{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability — allow main window + sidecar spawning",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "futhark-laguz",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
